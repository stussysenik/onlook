{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onlook",
  "version": "0.0.0",
  "identifier": "com.onlooknext.desktop",
  "build": {
    "beforeDevCommand": "bun --filter editor dev",
    "beforeBuildCommand": "bun --filter editor build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../editor-dist-placeholder"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Onlook",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
